NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Davet ve şifre sıfırlama e-postalarındaki linklerin döneceği taban URL.
# Boş bırakılırsa istek başlıklarından (host) türetilir; production'da
# stabil olması için doldurulması önerilir. Sondaki "/" konmamalı.
NEXT_PUBLIC_SITE_URL=https://kinocoach.com.tr

# Vercel cron (/api/cron/weekly-reminders) için zorunlu.
# Production'da güçlü, rastgele bir değer kullanın.
CRON_SECRET=generate-a-long-random-secret

# İletişim formu alıcısı. Boş bırakılırsa EMAIL_FROM kullanılır.
CONTACT_EMAIL=info@kinocoach.com.tr

# Uygulama içinden mail göndermek için SMTP ayarları.
# Supabase Auth SMTP kullanılmaz; Supabase sadece güvenli link üretir.
SMTP_HOST=mail.kinocoach.com.tr
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@kinocoach.com.tr
SMTP_PASS=mail_sifren
EMAIL_FROM=Kino Coach <noreply@kinocoach.com.tr>
